        <mxCell id="s2d" parent="s2g" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Runtime invoke&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;- &lt;/b&gt;Router calls invoke_agent_runtime with runtimeUserId=slack-user-&amp;lt;U&amp;gt; (per-user isolation)&lt;/span&gt;&lt;/div&gt;" vertex="1">
