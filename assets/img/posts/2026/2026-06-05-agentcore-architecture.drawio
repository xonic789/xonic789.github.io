        <mxCell id="s5d" parent="s5g" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;First-time consent (per-user 3LO)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;- &lt;/b&gt;Router pre-writes session_uri to DynamoDB; user consents at provider; AgentCore Identity callback hits API Gateway to Lambda, which looks up the row and calls complete_resource_token_auth to bind the token in the vault&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="558" x="52" as="geometry" />
        </mxCell>

