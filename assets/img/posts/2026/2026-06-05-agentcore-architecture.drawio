        <mxCell id="s4d" parent="s4g" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Tool calls via Gateway&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;- &lt;/b&gt;Runtime calls MCP tools on the Gateway hub (3 targets); Gateway makes per-user 3LO calls to Notion/Jira/GitHub using vault tokens&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="558" x="52" as="geometry" />
        </mxCell>

